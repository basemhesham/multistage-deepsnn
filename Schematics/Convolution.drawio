        <mxCell id="4CsY7YEodxtMPze0mRfh-315" parent="1" style="text;whiteSpace=wrap;fontSize=18;" value="Pooling Logic: Max-of-4 Selection using Subtractors and Muxes (1,118 Cycles for selection)." vertex="1">
