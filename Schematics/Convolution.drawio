        <mxCell id="8RKUqCa6QrMhcpAk5In_-294" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;font style=&quot;font-size: 23px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Adder Tree&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="210" x="910" y="210" as="geometry" />
        </mxCell>
        <mxCell id="8RKUqCa6QrMhcpAk5In_-295" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;" value="&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;2,0,0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;2,0,0&quot; data-index-in-node=&quot;0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Hardware Unit:&lt;/b&gt; 32 Parallel &lt;code data-path-to-node=&quot;2,0,0&quot; data-index-in-node=&quot;27&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;CONV9&lt;/code&gt; Units (Mapping 1:1 to Input Feature Maps).&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;2,1,0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;2,1,0&quot; data-index-in-node=&quot;0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Operation:&lt;/b&gt; Each unit performs &lt;span class=&quot;math-inline&quot; data-math=&quot;3 \times 3&quot; data-index-in-node=&quot;30&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;3 x 3&lt;/span&gt;&amp;nbsp;multiplication on a dedicated Feature Map.&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;2,2,0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;2,2,0&quot; data-index-in-node=&quot;0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Reduction Stage:&lt;/b&gt; 5-Level Adder Tree (31 Adders total: &lt;span class=&quot;math-inline&quot; data-math=&quot;16 \rightarrow 8 \rightarrow 4 \rightarrow 2 \rightarrow 1&quot; data-index-in-node=&quot;54&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;16 → 8 → 4 → 2 → 1&lt;/span&gt;).&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;2,3,0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;2,3,0&quot; data-index-in-node=&quot;0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Output:&lt;/b&gt; Summation of 32 units yields &lt;code data-path-to-node=&quot;2,3,0&quot; data-index-in-node=&quot;37&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Pixel_0&lt;/code&gt; (Result of Filter_0 applied to all 32 Feature Maps).&lt;/p&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="130" width="560" x="1120" as="geometry" />
        </mxCell>
        <mxCell id="8RKUqCa6QrMhcpAk5In_-296" edge="1" parent="1" style="endArrow=none;dashed=1;html=1;rounded=0;strokeWidth=4;fillColor=#f8cecc;strokeColor=#b85450;" value="">
