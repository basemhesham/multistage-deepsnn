        <mxCell id="8RKUqCa6QrMhcpAk5In_-183" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;p data-path-to-node=&quot;7&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;To process the entire Stage 2 (&lt;span class=&quot;math-inline&quot; data-math=&quot;256 \times 256&quot; data-index-in-node=&quot;31&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;128 x 128&lt;/span&gt;&amp;nbsp;image with 64 output filters):&lt;/p&gt;&lt;ul data-path-to-node=&quot;8&quot; style=&quot;padding-inline-start: 32px; font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;li style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;8,0,0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;8,0,0&quot; data-index-in-node=&quot;0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Total Output Pixels per Filter:&lt;/b&gt; &lt;span class=&quot;math-inline&quot; data-math=&quot;256 \times 256 = 65,536&quot; data-index-in-node=&quot;32&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;128 x 128 = 16384&lt;/span&gt;&amp;nbsp;pixels.&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;8,1,0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;8,1,0&quot; data-index-in-node=&quot;0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Total Filters to Process:&lt;/b&gt; 64.&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;8,2,0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;8,2,0&quot; data-index-in-node=&quot;0&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Calculation:&lt;/b&gt; &lt;/p&gt;&lt;div data-path-to-node=&quot;8,2,1&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;div class=&quot;math-block&quot; data-math=&quot;\text{Total Cycles} = 65,536 \text{ Pixels} \times 64 \text{ Filters} = \mathbf{4,194,304 \text{ Cycles}}&quot; style=&quot;line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Total Cycles = 16384&amp;nbsp;Pixels x 64 Filters = 1,048,576 Cycles&lt;/div&gt;&lt;/div&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
