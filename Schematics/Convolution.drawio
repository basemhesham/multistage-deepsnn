          </mxGeometry>
        </mxCell>
        <mxCell id="4CsY7YEodxtMPze0mRfh-318" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;strokeWidth=2;" value="&lt;font style=&quot;font-size: 15px;&quot;&gt;&lt;b&gt;Pool_out[2]&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="90" x="2727" y="912" as="geometry" />
        </mxCell>
        <mxCell id="4CsY7YEodxtMPze0mRfh-322" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=18;" value="&lt;b&gt;Convolutional Throughput: &lt;/b&gt;The system employs 32 parallel CONV25 units, allowing the simultaneous calculation of 32 pixels (one for each filter) in a single operation cycle.&lt;br&gt;&lt;b&gt;&lt;br&gt;Data Reduction:&lt;/b&gt; Following the convolution, the 32 computed pixels are processed through selection/pooling logic.&lt;br&gt;&lt;br&gt;&lt;b&gt;Final Output:&lt;/b&gt; By grouping these results (32 pixels / 4-input selection), the circuit produces 8 final outputs once the full operation cycle is completed." vertex="1">
          <mxGeometry height="190" width="730" x="765" y="1450" as="geometry" />
        </mxCell>
        <mxCell id="4CsY7YEodxtMPze0mRfh-324" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1" value="&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;5,3,0,0&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Logic: 4-to-1 Selection Tree&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;5,3,1,0&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Reduction Ratio: 32 Inputs&amp;nbsp;&amp;nbsp;&lt;span style=&quot;font-weight: normal;&quot;&gt;→&lt;/span&gt;&amp;nbsp;8 Outputs&lt;/p&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="80" width="480" x="2179" y="1100" as="geometry" />
        </mxCell>
        <mxCell id="4CsY7YEodxtMPze0mRfh-326" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;" value="&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;3,0,0&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;3,0,0&quot; data-index-in-node=&quot;0&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Convolution Units&lt;/b&gt;: 32 Parallel &lt;code data-path-to-node=&quot;3,0,0&quot; data-index-in-node=&quot;31&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;CONV25&lt;/code&gt; units (processing 32 filters simultaneously).&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;p data-path-to-node=&quot;3,1,0&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;b data-path-to-node=&quot;3,1,0&quot; data-index-in-node=&quot;0&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;Multipliers&lt;/b&gt;: &lt;b data-path-to-node=&quot;3,1,0&quot; data-index-in-node=&quot;13&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;800&lt;/b&gt; total (32 units &lt;span class=&quot;math-inline&quot; data-math=&quot;\times&quot; data-index-in-node=&quot;33&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;X&lt;/span&gt; 25 multipliers each).&lt;/p&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="80" width="289.25" x="510.37" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="4CsY7YEodxtMPze0mRfh-329" parent="1" style="text;whiteSpace=wrap;html=1;fontSize=15;" value="&lt;li&gt;&lt;p data-path-to-node=&quot;3,3,0&quot;&gt;&lt;b data-path-to-node=&quot;3,3,0&quot; data-index-in-node=&quot;0&quot;&gt;Bias Stage&lt;/b&gt;: &lt;b data-path-to-node=&quot;3,3,0&quot; data-index-in-node=&quot;12&quot;&gt;32 Adders&lt;/b&gt; used to add &lt;code data-path-to-node=&quot;3,3,0&quot; data-index-in-node=&quot;34&quot;&gt;bias_0&lt;/code&gt; to each generated feature map.&lt;/p&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="80" width="205" x="825" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="4CsY7YEodxtMPze0mRfh-331" parent="1" style="text;whiteSpace=wrap;fontSize=15;" value="ReLU Activation: 32 AND units (each 18-bit wide) used to zero out negative values based on the 19th sign bit (MSB)." vertex="1">
          <mxGeometry height="90" width="224.5" x="1040" y="1080" as="geometry" />
        </mxCell>
        <mxCell id="4CsY7YEodxtMPze0mRfh-334" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;span style=&quot;font-size: 18px;&quot;&gt;&lt;b&gt;Batch Normalization:&lt;/b&gt; Sequential Scalar Multiplier and Adder applying Y = (x. Y) + B.&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="371" x="1632" y="1100" as="geometry" />
